# Copy to .env and fill in.

# API-Football (api-football.com) — fixtures/results + odds.
FOOTBALL_API_KEY=your_api_football_key_here
FOOTBALL_API_BASE=https://v3.football.api-sports.io

# Sportmonks (sportmonks.com) — fixtures + advanced stats (xG, possession).
SPORTMONKS_API_KEY=
SPORTMONKS_API_BASE=https://api.sportmonks.com/v3/football

# TheStatsAPI — advanced stats (xG, possession) only.
THESTATSAPI_KEY=
THESTATSAPI_BASE=https://api.thestatsapi.com/v1

# The Odds API (the-odds-api.com) — multi-bookmaker odds.
THE_ODDS_API_KEY=
THE_ODDS_API_BASE=https://api.the-odds-api.com/v4
THE_ODDS_API_SPORT_KEY=soccer_epl

# Which provider handles each data type. Values: api_football, sportmonks,
# thestatsapi, the_odds_api (only if that provider supports the
# capability — see README "Providers"). ODDS_PROVIDER_FALLBACK is optional;
# leave empty to disable fallback. STATS_PROVIDER empty disables xG/possession
# fetching entirely (matches.xg_*/possession_* stay NULL).
FIXTURES_PROVIDER=api_football
ODDS_PROVIDER_PRIMARY=api_football
ODDS_PROVIDER_FALLBACK=
STATS_PROVIDER=

# PostgreSQL connection (SQLAlchemy URL, psycopg3 driver).
DATABASE_URL=postgresql+psycopg://footy:footy@localhost:5432/footy

# Model artifacts directory.
MODEL_DIR=models

# Betting knobs (paper mode only — no real bets are placed).
EDGE_THRESHOLD=0.05
KELLY_FRACTION=0.25

# Multi-league/multi-model training defaults (scripts/train_all.py).
# Comma-separated; both fields parse either form.
LEAGUES=La Liga,Premier League,Bundesliga,Serie A,Ligue 1
ACTIVE_ALGORITHMS=baseline,xgboost
TRAIN_WORKERS=4

# Provider-specific numeric league id (API-Football numbering) per league name
# in LEAGUES - scripts/run_scheduler.py needs this to sync automatically.
# A league with no entry here logs an error for that league only and doesn't
# block the rest (see run_scheduler.py's football_sync_predict).
LEAGUE_IDS=La Liga:140,World Cup:1
